{
  "name": "@git-lfs-hub/server",
  "type": "module",
  "scripts": {
    "config:vars": "git-lfs-hub-config vars . --env dev",
    "config": "git-lfs-hub-config worker .",
    "types": "wrangler types --env-interface CloudflareBindings",
    "compile": "tsgo --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun run compile && bun run lint && bun run format:check",
    "vitest": "bun run check && bunx vitest",
    "test": "bun vitest run",
    "test:unit": "bun run test --project unit",
    "test:integration": "bun run test --project 'integration*'",
    "test:scripts": "bun run test --project 'scripts'",
    "test:watch": "bun vitest watch",
    "test-coverage": "bun run test --coverage",
    "wrangler": "bun run check && wrangler",
    "dev": "bun wrangler dev --var ENV:local",
    "build": "bun wrangler deploy --dry-run --outdir dist",
    "predeploy": "! [ -f ../.config.json ] || scripts/assert-deploy-target.sh",
    "deploy": "bun wrangler deploy --minify --outdir dist $(scripts/sentry-wrangler-args.sh)",
    "sentry:sourcemaps": "scripts/sentry-upload-sourcemaps.sh",
    "postdeploy": "bun run sentry:sourcemaps && scripts/trigger-migration.sh"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": "^26.1.0"
  },
  "dependencies": {
    "@git-lfs-hub/lib": "file:../lib",
    "@hono/standard-validator": "^0.2.2",
    "@sentry/cloudflare": "^10.56.0",
    "@sentry/hono": "^10.56.0",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "handlebars": "^4.7.9",
    "hono": "^4.12.23",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.13",
    "@git-lfs-hub/config": "file:../config",
    "@sentry/cli": "^3.5.0",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "^7.0.0-dev.20260606.1",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "miniflare": "^4.20260603.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
}
