{
  "name": "@git-lfs-hub/server",
  "type": "module",
  "scripts": {
    "config": "git-lfs-hub-config init --server . --env dev && bun run types",
    "types": "wrangler types --env-interface CloudflareBindings",
    "compile": "tsgo --noEmit",
    "pretest": "bun run compile",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project 'integration*'",
    "test:scripts": "vitest run --project 'scripts'",
    "test:watch": "vitest watch",
    "test-coverage": "bun run test --coverage",
    "dev": "wrangler dev --var ENV:local",
    "prebuild": "bun run compile",
    "build": "wrangler deploy --dry-run --outdir dist",
    "predeploy": "! [ -f ../.config.json ] || scripts/assert-deploy-target.sh",
    "deploy": "wrangler deploy --minify --outdir dist $(scripts/sentry-wrangler-args.sh)",
    "sentry:sourcemaps": "scripts/sentry-upload-sourcemaps.sh",
    "postdeploy": "bun run sentry:sourcemaps && scripts/trigger-migration.sh"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": "^26.1.0"
  },
  "dependencies": {
    "@git-lfs-hub/lib": "file:../lib",
    "@hono/standard-validator": "^0.2.2",
    "@sentry/cloudflare": "^10.56.0",
    "@sentry/hono": "^10.56.0",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "handlebars": "^4.7.9",
    "hono": "^4.12.23",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.12",
    "@git-lfs-hub/config": "file:../config",
    "@sentry/cli": "^3.5.0",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260603.1",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "miniflare": "^4.20260601.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.97.0"
  }
}
